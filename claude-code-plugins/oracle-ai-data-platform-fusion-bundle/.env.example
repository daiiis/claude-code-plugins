# oracle-ai-data-platform-fusion-bundle example environment variables
#
# Copy to .env for local development only. Keep .env gitignored.
# Production bundles should prefer aidp.config.yaml plus AIDP credential-store
# entries for secrets.
#
# NOTE: keep comments on their OWN line, never trailing an assignment.
# `KEY=    # comment` is parsed by python-dotenv as KEY="# comment" (the
# comment becomes the value), which silently poisons every variable when the
# file is copied to .env and auto-loaded by the CLI.

# -------- Required by the current customer bundle templates --------
# Referenced from examples/minimal-bundle/bundle.yaml and generated bundles.

# https://<your-fusion-pod-host>
FUSION_BICC_BASE_URL=
# Fusion user with BICC privileges
FUSION_BICC_USER=
# local/bootstrap only; production loads from AIDP credential store
FUSION_BICC_PASSWORD=
# BICC console External Storage profile name
FUSION_BICC_EXTERNAL_STORAGE=
# OCI_BUCKET_BICC — informational only; configured inside the BICC External Storage profile
# OCI_BUCKET_BICC=

# OAC instance used for dataset/workbook work and MCP setup.
# https://<your-oac-host>
OAC_URL=

# -------- Operator OAC MCP setup --------
# Used by:
#   aidp-fusion-bundle dashboard mcp-setup --connector-js <path>
# The command writes credentials to ~/.oac-connect/oac_mcp_connect_config.json
# with mode 0600 and wires .mcp.json without committing secrets.

# least-privilege OAC operator user
OAC_MCP_USER=
# password for OAC_MCP_USER; CLI also accepts --password '${vault:<secret-ocid>}'
OAC_MCP_PASSWORD=
# optional direct .mcp.json path, e.g. ~/oac-mcp-connect/oac-mcp-connect.js
OAC_MCP_CONNECT_PATH=

# -------- Optional AIDP live-helper / contributor variables --------
# Normal customer runs should use aidp.config.yaml instead of these env vars.
# These are used by tests/live/* and skills/incremental-mechanism helpers.
AIDP_REGION=us-ashburn-1
AIDP_OCI_PROFILE=AIDP_SESSION
# Data Lake / AIDP OCID used by dispatch live helpers
AIDP_ID=
# same value as AIDP_ID; used by catalog/state probe helpers
AIDP_DATALAKE_OCID=
# workspace UUID
AIDP_WORKSPACE_KEY=
# cluster UUID used by dispatch live helpers
AIDP_CLUSTER_KEY=
# same value as AIDP_CLUSTER_KEY; used by older catalog/state probes
AIDP_CLUSTER_ID=
AIDP_CLUSTER_NAME=fusion_bundle_dev
# display-name alias used by catalog/state probes
AIDP_CLUSTER=fusion_bundle_dev
AIDP_CATALOG=fusion_catalog

# -------- Optional bootstrap/operator overrides --------
# overrides USER for audit identity
AIDP_OPERATOR=
# bootstrap CLI override; otherwise use aidp.config.yaml
AIDP_FUSION_CLUSTER_KEY=
# bootstrap CLI override; otherwise use aidp.config.yaml
AIDP_FUSION_CLUSTER_NAME=
# bootstrap CLI override; usually derived automatically
AIDP_FUSION_WORKSPACE_DIR=

# -------- Optional test toggles --------
# set to 1 for live tests only
AIDP_FUSION_BUNDLE_INTEGRATION=0
# AIDP_FUSION_BUNDLE_MOCK_SECRETS=ocid1.vaultsecret...=value
