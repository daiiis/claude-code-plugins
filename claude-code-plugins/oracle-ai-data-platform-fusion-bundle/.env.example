# oracle-ai-data-platform-fusion-bundle example environment variables
#
# Copy to .env for local development only. Keep .env gitignored.
# Production bundles should prefer aidp.config.yaml plus AIDP credential-store
# entries for secrets.

# -------- Required by the current customer bundle templates --------
# Referenced from examples/minimal-bundle/bundle.yaml and generated bundles.
FUSION_BICC_BASE_URL=                  # https://<your-fusion-pod-host>
FUSION_BICC_USER=                      # Fusion user with BICC privileges
FUSION_BICC_PASSWORD=                  # local/bootstrap only; production loads from AIDP credential store
FUSION_BICC_EXTERNAL_STORAGE=          # BICC console External Storage profile name
# OCI_BUCKET_BICC=                     # informational only; configured inside the BICC External Storage profile

# OAC instance used for dataset/workbook work and MCP setup.
OAC_URL=                               # https://<your-oac-host>

# -------- Operator OAC MCP setup --------
# Used by:
#   aidp-fusion-bundle dashboard mcp-setup --connector-js <path>
# The command writes credentials to ~/.oac-connect/oac_mcp_connect_config.json
# with mode 0600 and wires .mcp.json without committing secrets.
OAC_MCP_USER=                          # least-privilege OAC operator user
OAC_MCP_PASSWORD=                      # password for OAC_MCP_USER; CLI also accepts --password '${vault:<secret-ocid>}'
OAC_MCP_CONNECT_PATH=                  # optional direct .mcp.json path, e.g. ~/oac-mcp-connect/oac-mcp-connect.js

# -------- Optional AIDP live-helper / contributor variables --------
# Normal customer runs should use aidp.config.yaml instead of these env vars.
# These are used by tests/live/* and skills/incremental-mechanism helpers.
AIDP_REGION=us-ashburn-1
AIDP_OCI_PROFILE=AIDP_SESSION
AIDP_ID=                               # Data Lake / AIDP OCID used by dispatch live helpers
AIDP_DATALAKE_OCID=                    # same value as AIDP_ID; used by catalog/state probe helpers
AIDP_WORKSPACE_KEY=                    # workspace UUID
AIDP_CLUSTER_KEY=                      # cluster UUID used by dispatch live helpers
AIDP_CLUSTER_ID=                       # same value as AIDP_CLUSTER_KEY; used by older catalog/state probes
AIDP_CLUSTER_NAME=fusion_bundle_dev
AIDP_CLUSTER=fusion_bundle_dev         # display-name alias used by catalog/state probes
AIDP_CATALOG=fusion_catalog

# Optional bootstrap/operator overrides.
AIDP_OPERATOR=                         # overrides USER for audit identity
AIDP_FUSION_CLUSTER_KEY=               # bootstrap CLI override; otherwise use aidp.config.yaml
AIDP_FUSION_CLUSTER_NAME=              # bootstrap CLI override; otherwise use aidp.config.yaml
AIDP_FUSION_WORKSPACE_DIR=             # bootstrap CLI override; usually derived automatically

# -------- Optional test toggles --------
AIDP_FUSION_BUNDLE_INTEGRATION=0       # set to 1 for live tests only
# AIDP_FUSION_BUNDLE_MOCK_SECRETS=ocid1.vaultsecret...=value
